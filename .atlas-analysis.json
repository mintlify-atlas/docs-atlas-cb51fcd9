  "keyFeatures": [
    "High-throughput LLM inference with PagedAttention",
    "OpenAI-compatible API server",
    "Multi-GPU tensor and pipeline parallelism",
    "Quantization support (GPTQ, AWQ, INT4/INT8/FP8)",
    "Continuous batching and speculative decoding",
    "Multi-LoRA adapters and prefix caching",
    "Support for 70K+ stars with AMD, NVIDIA, TPU backends"
  ],
  "publicApiSurface": [
    "LLM - Main inference class",
    "AsyncLLMEngine - Async inference engine",
    "LLMEngine - Synchronous inference engine",
    "SamplingParams - Control generation behavior",
    "PoolingParams - Configure pooling/embedding models",
    "EngineArgs - Engine configuration",
    "AsyncEngineArgs - Async engine configuration",
    "RequestOutput - Generation output format",
    "CompletionOutput - Completion output format",
    "EmbeddingOutput - Embedding output format",
    "vllm serve - Start OpenAI-compatible server",
    "vllm chat - Interactive chat interface",
    "vllm complete - Single completion generation",
    "vllm run-batch - Batch offline inference",
    "vllm bench - Benchmarking utilities"
  ]
